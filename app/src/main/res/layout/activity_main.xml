<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Fullscreen cola liquid view - the main effect -->
    <com.colashake.counter.ColaScreenView
        android:id="@+id/colaScreenView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Anime girl in background (bottom-left area) -->
    <com.colashake.counter.AnimeGirlView
        android:id="@+id/animeGirlView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Counter in top-right -->
    <TextView
        android:id="@+id/counterText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="32dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="56sp"
        android:textStyle="bold"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4" />

</FrameLayout>
